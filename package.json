{
  "name": "world-cup-2026-predictor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "verify": "pnpm typecheck && pnpm lint && CI=true pnpm test && pnpm build",
    "db:migrate:postgres": "tsx scripts/apply-postgres-migration.ts",
    "db:seed:postgres": "tsx --conditions=react-server scripts/seed-postgres.ts",
    "smoke:persist": "tsx --conditions=react-server scripts/smoke-persist-prediction.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/supabase-js": "^2.108.1",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
