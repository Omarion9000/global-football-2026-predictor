# =============================================================================
# .env.example
# =============================================================================
# Copy to `.env.local` for local development. NEVER commit `.env.local` —
# it is in `.gitignore`. In production, set these in Vercel project settings
# (`vercel env add`).
# =============================================================================

# Shared secret used to authenticate Vercel Cron invocations of the
# /api/cron/predictions route. The cron platform sends this as
# `Authorization: Bearer ${CRON_SECRET}`.
#
# Behaviour by environment:
#   - production : REQUIRED. Missing or mismatched secret returns 401.
#   - development: OPTIONAL. If omitted, the route allows unauthenticated
#                  requests for ergonomic local testing only.
CRON_SECRET=replace-me-in-vercel-project-settings
