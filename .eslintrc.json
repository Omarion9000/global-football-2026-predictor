{
  "root": true,
  "extends": ["next/core-web-vitals"],
  "ignorePatterns": [
    "node_modules",
    ".next",
    "out",
    "build",
    "coverage",
    "next-env.d.ts"
  ],
  "overrides": [
    {
      "files": [
        "src/lib/model/**/*.{ts,tsx}",
        "src/lib/simulation/**/*.{ts,tsx}",
        "src/lib/normalization/**/*.{ts,tsx}",
        "src/lib/scheduler/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "react",
              "react/*",
              "react-dom",
              "react-dom/*",
              "next",
              "next/*",
              "@/components",
              "@/components/*",
              "@/app",
              "@/app/*"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/components/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@/lib/model",
              "@/lib/model/*",
              "@/lib/simulation",
              "@/lib/simulation/*",
              "@/lib/normalization",
              "@/lib/normalization/*",
              "@/lib/utils/rng",
              "@/lib/utils/poisson",
              "@supabase/supabase-js",
              "@/lib/data/supabase",
              "@/lib/data/supabase/*",
              "@/lib/data/persistence/supabase",
              "@/lib/data/persistence/supabase/*",
              "@neondatabase/serverless",
              "@/lib/data/postgres",
              "@/lib/data/postgres/*",
              "@/lib/data/persistence/postgres",
              "@/lib/data/persistence/postgres/*",
              "@/lib/data/persistence/repositoryFactory",
              "@/lib/data/smoke",
              "@/lib/data/smoke/*",
              "@/lib/data/uiReadModel",
              "server-only"
            ]
          }
        ]
      }
    }
  ]
}
